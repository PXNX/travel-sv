		"leaflet": "1.9.4",
		"oslo": "1.2.1",
		"postgres": "3.4.8",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"sveaflet": "0.1.4",
		"svelte": "5.55.0",
		"sveltekit-superforms": "2.30.0",
